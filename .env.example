# ============================================================
# ai-video-gen — environment variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Google Veo (Vertex AI) ---
# Required when using --provider veo
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1
# GCS bucket for video output (without gs:// prefix)
# Create one with: gcloud storage buckets create gs://your-bucket --location=us-central1
GCS_BUCKET=your-gcs-bucket-name

# --- Future providers ---
# Uncomment and fill in when using other providers

# Runway
# RUNWAY_API_KEY=your-runway-api-key

# Kling
# KLING_API_KEY=your-kling-api-key

# MiniMax
# MINIMAX_API_KEY=your-minimax-api-key
